{
  "name": "discover_services_filtered",
  "description": "canopy.discover({category, query}) hits /api/services with the right filters and the auto-attached agent_id, and returns the parsed list.",
  "config": {
    "apiKey": "ak_live_test",
    "agentId": "agt_test",
    "baseUrl": "https://api.canopy.test"
  },
  "call": {
    "method": "discover",
    "args": { "category": "data", "query": "orderbook" }
  },
  "httpExchange": [
    {
      "request": {
        "method": "GET",
        "url": "https://api.canopy.test/api/services?category=data&q=orderbook&agent_id=agt_test",
        "headers": {
          "authorization": "Bearer ak_live_test"
        }
      },
      "response": {
        "status": 200,
        "body": {
          "services": [
            {
              "slug": "coinglass",
              "name": "Coinglass Orderbook Feed",
              "description": "Real-time order book depth across major exchanges.",
              "category": "data",
              "logoUrl": null,
              "docsUrl": null,
              "paymentMethods": [
                {
                  "realm": "coinglass.x402.com",
                  "baseUrl": "https://coinglass.x402.com",
                  "protocol": "x402"
                }
              ],
              "endpoints": [
                {
                  "method": "GET",
                  "path": "/v1/orderbook",
                  "description": "Real-time order book depth.",
                  "priceAtomic": "10000",
                  "currency": "USDC",
                  "pricingModel": "fixed",
                  "protocol": "x402"
                }
              ],
              "preferredBaseUrl": "https://coinglass.x402.com",
              "policyAllowed": true
            }
          ],
          "count": 1
        }
      }
    }
  ],
  "expectedReturn": [
    {
      "slug": "coinglass",
      "name": "Coinglass Orderbook Feed",
      "category": "data",
      "preferredBaseUrl": "https://coinglass.x402.com",
      "policyAllowed": true
    }
  ]
}
