{
  "name": "discover_services_policy_blocked",
  "description": "With include_blocked=true, /api/services returns policy-blocked services with policyAllowed=false. SDK passes that flag through and surfaces the field.",
  "config": {
    "apiKey": "ak_live_test",
    "agentId": "agt_test",
    "baseUrl": "https://api.canopy.test"
  },
  "call": {
    "method": "discover",
    "args": { "includeBlocked": true }
  },
  "httpExchange": [
    {
      "request": {
        "method": "GET",
        "url": "https://api.canopy.test/api/services?include_blocked=true&agent_id=agt_test"
      },
      "response": {
        "status": 200,
        "body": {
          "services": [
            {
              "slug": "allowed-feed",
              "name": "Allowed Feed",
              "description": "On the agent's allowlist.",
              "category": "data",
              "logoUrl": null,
              "docsUrl": null,
              "paymentMethods": [
                {
                  "realm": "allowed.example",
                  "baseUrl": "https://allowed.example",
                  "protocol": "x402"
                }
              ],
              "endpoints": [],
              "preferredBaseUrl": "https://allowed.example",
              "policyAllowed": true
            },
            {
              "slug": "blocked-feed",
              "name": "Blocked Feed",
              "description": "Policy-blocked; returned because include_blocked=true.",
              "category": "data",
              "logoUrl": null,
              "docsUrl": null,
              "paymentMethods": [
                {
                  "realm": "blocked.example",
                  "baseUrl": "https://blocked.example",
                  "protocol": "x402"
                }
              ],
              "endpoints": [],
              "preferredBaseUrl": "https://blocked.example",
              "policyAllowed": false
            }
          ],
          "count": 2
        }
      }
    }
  ],
  "expectedReturn": [
    { "name": "Allowed Feed", "policyAllowed": true },
    { "name": "Blocked Feed", "policyAllowed": false }
  ]
}
